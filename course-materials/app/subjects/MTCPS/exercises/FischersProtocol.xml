			<source ref="id3"/>
			<target ref="id4"/>
			<label kind="guard" x="238" y="102">x&gt;=D2</label>
		</transition>
		<transition>
			<source ref="id2"/>
			<target ref="id3"/>
			<label kind="assignment" x="306" y="34">Turn=myID,
x=0</label>
